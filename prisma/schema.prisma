generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  aiName    String?  @map("ai_name")
  location  String?  // city or area, e.g. "Los Angeles, CA"
  timezone  String?  // IANA timezone, e.g. "America/Los_Angeles"
  tier      String   @default("free") // "free" or "pro"
  stripeCustomerId String? @unique @map("stripe_customer_id")
  stripeSubId      String? @map("stripe_sub_id")
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  aiState          AiState?
  messages         Message[]
  memories         Memory[]
  feedItems        FeedItem[]
  threads          Thread[]
  backgroundEvents BackgroundEvent[]
  interactions     Interaction[]
  notifications    Notification[]
  reminders          Reminder[]
  pushSubscriptions  PushSubscription[]
  discoveryAnswers   DiscoveryAnswer[]
  usageLogs          UsageLog[]
  creditTransactions CreditTransaction[]
  characters         Character[]
  bubbleProfile      BubbleProfile?
  bubbleSignals      BubbleSignal[]
  bubbleCategories   BubbleCategory[]
  connectionsAsA     BubbleConnection[] @relation("connectionsAsA")
  connectionsAsB     BubbleConnection[] @relation("connectionsAsB")
  videoJobs          VideoJob[]
  collabProposalsA   CollabProposal[]   @relation("collabUserA")
  collabProposalsB   CollabProposal[]   @relation("collabUserB")
  businesses         Business[]
  facebookAccounts   FacebookAccount[]
  adCampaigns        AdCampaign[]
  orbitProjects      OrbitProject[]

  // Wallet system — dollar balance stored in cents ($5.00 = 500)
  walletBalance   Int    @default(0) @map("wallet_balance")    // balance in cents
  creditBalance   Int    @default(0) @map("credit_balance")    // DEPRECATED — kept for migration safety
  videoCredits    Int    @default(0) @map("video_credits")     // DEPRECATED — kept for migration safety
  freeMessages    Int    @default(0) @map("free_messages")     // DEPRECATED — default 0, no freebies
  personiCharId   String? @map("personi_char_id")              // linked Personi character ID
  mission         String? @map("mission")                     // user's WHY — why they created the AI, what they need it to do
  onboardingComplete Boolean @default(false) @map("onboarding_complete") // true after finishing new onboarding flow

  // Business profile — required for Content Pack
  businessType     String?  @map("business_type")
  businessName     String?  @map("business_name")
  specialties      String?  @map("specialties")
  targetAudience   String?  @map("target_audience")

  @@map("users")
}


model AiState {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tone         String   @default("warm")
  energy       String   @default("neutral")
  traits       Json     @default("[]")
  context      Json     @default("{}")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ai_state")
}

model Message {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String
  content     String
  threadId    String?    @map("thread_id")
  thread      Thread?    @relation(fields: [threadId], references: [id])
  characterId String?    @map("character_id")
  character   Character? @relation(fields: [characterId], references: [id])
  createdAt   DateTime   @default(now()) @map("created_at")
  metadata    Json?      @map("metadata")

  @@index([userId, createdAt])
  @@index([userId, characterId, createdAt])
  @@map("messages")
}

model Memory {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  content   String
  source    String?
  weight    Float     @default(1.0)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId, type])
  @@index([userId, createdAt])
  @@map("memory")
}

model FeedItem {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  content     String
  referenceId String?  @map("reference_id")
  seen        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("feed_items")
}

model Thread {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  status    String   @default("active")
  summary   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages Message[]

  @@index([userId, status])
  @@map("threads")
}

model BackgroundEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json     @default("{}")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("background_events")
}

model Interaction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("interactions")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String
  referenceId String?  @map("reference_id")
  type        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("notifications")
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  dueAt     DateTime @map("due_at")
  fired     Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, fired, dueAt])
  @@map("reminders")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String   // encryption key
  auth      String   // auth secret
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("push_subscriptions")
}

model DiscoveryAnswer {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   @map("question_id")  // maps to registry ID like "l1_think_about"
  level      Int      @default(1)
  answer     String
  source     String   @default("chat")      // "chat" or "settings"
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, questionId])
  @@index([userId, level])
  @@map("discovery_answers")
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "chat", "feed_gen", "notification", "search", "vision"
  tokens    Int      @default(0)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("usage_logs")
}

// ============================================
// CREDIT SYSTEM
// ============================================
model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "deposit", "video_charge", "refund", "adjustment"
  amountCents Int    @map("amount_cents")  // positive = added, negative = charged (in cents)
  balanceAfterCents Int @map("balance_after_cents") // wallet balance after this transaction (cents)
  description String @default("")  // human-readable, e.g. "Video generation — 3 scenes"
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  // Keep old columns for migration safety — Prisma won't break existing data
  amount    Int      @default(0) // DEPRECATED
  resource  String   @default("wallet") // DEPRECATED
  balanceAfter Int   @default(0) @map("balance_after") // DEPRECATED

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("credit_transactions")
}

// ============================================
// CHARACTER SYSTEM (Personi integration)
// ============================================
model Character {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personiId       String?  @map("personi_id")   // ID from Personi's database
  name            String
  personality     Json     @default("{}")        // full personality blob from Personi
  backstory       String?                        // character's background/origin story
  speakingStyle   String?  @map("speaking_style") // how the character talks (tone, cadence, phrases)
  interests       Json     @default("[]")        // character's interests and passions
  imageUrls       Json     @default("[]") @map("image_urls") // 3-4 profile pic URLs
  voiceStyle      String?  @map("voice_style")   // TTS voice preference
  isActive        Boolean  @default(false) @map("is_active") // currently active persona for chat

  // --- Personi bundle selections & customizations ---
  selections      Json     @default("{}")         // bundle picks per category e.g. { identity: "the-creator", backstory: "rags-to-riches" }
  customizations  Json     @default("{}")         // custom text overrides, reminders config, etc.
  compiledPrompt  String?  @map("compiled_prompt") // full system prompt assembled from bundles
  nicheType       String?  @map("niche_type")     // e.g. "Fitness", "Beauty", "Tech"
  nicheAudience   String?  @map("niche_audience") // target audience description
  missionStatement String? @map("mission_statement") // character's mission
  uniqueEdge      String?  @map("unique_edge")    // what makes this character stand out
  contentPillars  Json     @default("[]") @map("content_pillars") // AI-suggested content pillars

  visualTraits    Json     @default("{}") @map("visual_traits") // face/body trait selections for image generation

  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  videoJobs       VideoJob[]
  messages        Message[]
  characterImages CharacterImage[]

  @@index([userId])
  @@unique([userId, personiId])
  @@map("characters")
}

// ============================================
// CHARACTER IMAGES (generated profile images)
// ============================================
model CharacterImage {
  id          String   @id @default(cuid())
  characterId String   @map("character_id")
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  imageType   String   @map("image_type")  // "head_front", "head_left", "head_right", "body_front", "body_left", "body_right"
  imageUrl    String   @map("image_url")
  position    Int      @default(0)          // display order
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([characterId])
  @@unique([characterId, imageType])
  @@map("character_images")
}

// ============================================
// VIDEO GENERATION PIPELINE
// ============================================
model VideoJob {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId   String   @map("character_id")
  character     Character @relation(fields: [characterId], references: [id])
  status        String   @default("pending")  // "pending", "scripting", "generating", "stitching", "ready", "failed"
  script        Json     @default("{}")       // the video script from script engine
  scenes        Json     @default("[]")       // scene generation results (URLs, status per scene)
  narrationUrl  String?  @map("narration_url")  // TTS audio file URL
  finalVideoUrl String?  @map("final_video_url") // stitched output
  totalCost     Float    @default(0) @map("total_cost")  // actual API cost tracked
  duration      Int      @default(15)          // target duration in seconds
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([createdAt])
  @@map("video_jobs")
}

// ============================================
// BUSINESS PROFILES (multi-business per user)
// ============================================
model Business {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String   // business name
  websiteUrl       String?  @map("website_url")
  businessType     String?  @map("business_type")
  productsServices String?  @map("products_services") @db.Text
  targetAudience   String?  @map("target_audience") @db.Text
  socialLinks      Json     @default("[]") @map("social_links") // [{platform, url}]
  location         String?
  brandVoice       String?  @map("brand_voice")
  scrapedData      Json?    @map("scraped_data") // raw AI-extracted info from links
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("businesses")
}

// ============================================
// ECHOVERSE: BUBBLE WORLD SYSTEM
// ============================================

model BubbleProfile {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalSummary  Json     @default("{}") @map("signal_summary")
  profileVector  Json     @default("[]") @map("profile_vector")
  totalSignals   Int      @default(0) @map("total_signals")
  lastComputedAt DateTime @default(now()) @map("last_computed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("bubble_profiles")
}

model BubbleSignal {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalType      String   @map("signal_type")
  signalKey       String   @map("signal_key")
  signalValue     String   @default("") @map("signal_value")
  strength        Float    @default(1.0)
  occurrenceCount Int      @default(1) @map("occurrence_count")
  source          String   @default("chat")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, signalType, signalKey])
  @@index([userId])
  @@index([userId, signalType])
  @@map("bubble_signals")
}

model BubbleCategory {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryName    String   @map("category_name")
  categorySignals Json     @default("[]") @map("category_signals")
  weight          Float    @default(1.0)
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, status])
  @@map("bubble_categories")
}

model BubbleConnection {
  id                 String   @id @default(cuid())
  userAId            String   @map("user_a_id")
  userA              User     @relation("connectionsAsA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId            String   @map("user_b_id")
  userB              User     @relation("connectionsAsB", fields: [userBId], references: [id], onDelete: Cascade)
  overlapScore       Float    @default(0.0) @map("overlap_score")
  matchingCategories Json     @default("[]") @map("matching_categories")
  matchingSignals    Json     @default("[]") @map("matching_signals")
  status             String   @default("detected")
  surfacedToA        Boolean  @default(false) @map("surfaced_to_a")
  surfacedToB        Boolean  @default(false) @map("surfaced_to_b")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  echoConversations EchoConversation[]

  @@index([userAId, userBId])
  @@index([status])
  @@map("bubble_connections")
}

model EchoConversation {
  id           String           @id @default(cuid())
  connectionId String           @map("connection_id")
  connection   BubbleConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  aiASummary   String           @default("") @map("ai_a_summary")
  aiBSummary   String           @default("") @map("ai_b_summary")
  exchangeLog  Json             @default("[]") @map("exchange_log")
  surfaceToA   String           @default("") @map("surface_to_a")
  surfaceToB   String           @default("") @map("surface_to_b")
  status       String           @default("pending")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([connectionId])
  @@index([status])
  
  collabProposals CollabProposal[]

  @@map("echo_conversations")
}


// ============================================
// WHAT'S COOKING: COLLABORATION SYSTEM
// ============================================

model CollabProposal {
  id              String   @id @default(cuid())
  echoConvoId     String   @map("echo_convo_id")
  echoConvo       EchoConversation @relation(fields: [echoConvoId], references: [id], onDelete: Cascade)
  userAId         String   @map("user_a_id")
  userA           User     @relation("collabUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId         String   @map("user_b_id")
  userB           User     @relation("collabUserB", fields: [userBId], references: [id], onDelete: Cascade)
  title           String   // short collab title, e.g. "30-Day Fitness Challenge"
  description     String   // what the collab is about
  optionA         String   @map("option_a") // first direction to vote on
  optionB         String   @map("option_b") // second direction to vote on
  votesA          Int      @default(0) @map("votes_a")
  votesB          Int      @default(0) @map("votes_b")
  status          String   @default("cooking") // "cooking", "decided", "launched", "cancelled"
  acceptedByA     Boolean  @default(false) @map("accepted_by_a")
  acceptedByB     Boolean  @default(false) @map("accepted_by_b")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  votes           CollabVote[]

  @@index([status])
  @@index([userAId])
  @@index([userBId])
  @@map("collab_proposals")
}

model CollabVote {
  id              String   @id @default(cuid())
  proposalId      String   @map("proposal_id")
  proposal        CollabProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voterId         String?  @map("voter_id") // null = anonymous public voter
  choice          String   // "a" or "b"
  voterFingerprint String? @map("voter_fingerprint") // for anonymous dedup
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([proposalId])
  @@index([voterId])
  @@map("collab_votes")
}


// ============================================
// META ADS: FACEBOOK/INSTAGRAM AD SYSTEM
// ============================================
model FacebookAccount {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fbUserId           String    @map("fb_user_id")
  accessToken        String    @map("access_token") @db.Text
  tokenExpiresAt     DateTime  @map("token_expires_at")
  fbPageId           String?   @map("fb_page_id")
  fbPageName         String?   @map("fb_page_name")
  fbPageAccessToken  String?   @map("fb_page_access_token") @db.Text
  igAccountId        String?   @map("ig_account_id")
  adAccountId        String?   @map("ad_account_id")
  permissions        Json      @default("[]")
  status             String    @default("active") // "active", "expired", "revoked"
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  adCampaigns        AdCampaign[]

  @@unique([userId, fbUserId])
  @@index([userId])
  @@map("facebook_accounts")
}

model AdCampaign {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  facebookAccountId   String    @map("facebook_account_id")
  facebookAccount     FacebookAccount @relation(fields: [facebookAccountId], references: [id], onDelete: Cascade)
  metaCampaignId      String?   @map("meta_campaign_id")
  metaAdSetId         String?   @map("meta_ad_set_id")
  metaAdCreativeId    String?   @map("meta_ad_creative_id")
  metaAdId            String?   @map("meta_ad_id")
  name                String
  objective           String    @default("OUTCOME_AWARENESS")
  status              String    @default("draft") // "draft", "pending", "active", "paused", "completed", "failed"
  adFormat            String    @map("ad_format") // "image", "video", "carousel", "story"
  content             Json      @default("{}") // ad content: text, media URLs, headline, CTA
  targeting           Json      @default("{}") // locations, age range, interests, genders
  budget              Json      @default("{}") // dailyBudget or lifetimeBudget in cents, currency
  schedule            Json      @default("{}") // start/end dates, timezone
  metrics             Json      @default("{}") // cached: impressions, clicks, spend, reach, cpc, cpm
  metricsUpdatedAt    DateTime? @map("metrics_updated_at")
  chargeAmountCents   Int       @default(0) @map("charge_amount_cents")
  errorMessage        String?   @map("error_message")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([metaCampaignId])
  @@map("ad_campaigns")
}


// ============================================
// GEMINI IMAGE QUOTA TRACKING
// ============================================
model ImageQuota {
  id          String   @id @default(cuid())
  date        String   @unique // "2026-05-25" format, one row per day
  freeUsed    Int      @default(0) @map("free_used") // images generated on free tier today
  paidUsed    Int      @default(0) @map("paid_used") // images generated on paid tier today
  paidCostCents Int    @default(0) @map("paid_cost_cents") // total paid cost in cents today
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("image_quotas")
}

// Per-user image generation log
model ImageGeneration {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  characterId String?  @map("character_id")
  promptUsed  String   @db.Text @map("prompt_used")
  referenceUrl String? @map("reference_url") // the scene photo URL
  resultUrl   String?  @map("result_url") // generated image URL
  tier        String   @default("free") // "free" or "paid"
  costCents   Int      @default(0) @map("cost_cents")
  status      String   @default("pending") // "pending", "completed", "failed"
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("image_generations")
}


// ============================================
// CONTINUUM ORBIT: MULTI-AI INFLUENCER NETWORK
// ============================================

model OrbitProject {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String   // project name
  websiteUrl      String?  @map("website_url")
  description     String   @db.Text
  industry        String?  // niche or industry
  targetAudience  String?  @map("target_audience") @db.Text
  objective       String   @default("awareness") // awareness, traffic, signups, sales, audience_growth
  characterCount  Int      @default(6) @map("character_count") // 3 or 6
  strategyTable   Json     @default("[]") @map("strategy_table") // [{character, role, contentAngle, goal}]
  status          String   @default("draft") // draft, generating, active, paused, archived
  totalCostCents  Int      @default(0) @map("total_cost_cents") // total spent generating this orbit
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  characters      OrbitCharacter[]
  posts            OrbitPost[]

  @@index([userId])
  @@index([status])
  @@map("orbit_projects")
}

model OrbitCharacter {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  project         OrbitProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleType        String   @map("role_type") // main_character, builder, chaos, expert, mystery, social_connector
  name            String
  username        String?  // suggested social handle
  appearance      Json     @default("{}") // physical appearance, visual style
  personality     Json     @default("{}") // traits, speech patterns, emotional tendencies, values, goals, strengths, flaws
  behavior        Json     @default("{}") // posting style, humor, social behavior, reaction patterns, confidence
  contentProfile  Json     @default("{}") @map("content_profile") // themes, angles, hooks, formats, catchphrases, viral triggers
  imagePrompt     String?  @map("image_prompt") @db.Text // prompt for generating profile images
  profileImages   Json     @default("[]") @map("profile_images") // up to 6 image URLs
  contentAngle    String?  @map("content_angle") // unique content angle (from strategy table)
  goal            String?  // character's goal aligned to project objective
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  relationshipsAsA OrbitRelationship[] @relation("orbitRelA")
  relationshipsAsB OrbitRelationship[] @relation("orbitRelB")
  posts            OrbitPost[]

  @@index([projectId])
  @@index([roleType])
  @@map("orbit_characters")
}

model OrbitRelationship {
  id              String   @id @default(cuid())
  characterAId    String   @map("character_a_id")
  characterA      OrbitCharacter @relation("orbitRelA", fields: [characterAId], references: [id], onDelete: Cascade)
  characterBId    String   @map("character_b_id")
  characterB      OrbitCharacter @relation("orbitRelB", fields: [characterBId], references: [id], onDelete: Cascade)
  relationshipType String  @map("relationship_type") // friend, rival, collaborator, mentor, subordinate, mysterious_connection, hidden_tension
  description     String?  @db.Text // narrative description of the relationship
  interactionIdeas Json    @default("[]") @map("interaction_ideas") // content ideas born from this relationship
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([characterAId, characterBId])
  @@index([characterAId])
  @@index([characterBId])
  @@map("orbit_relationships")
}

model OrbitPost {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  project         OrbitProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterId     String    @map("character_id")
  character       OrbitCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  content         String    @db.Text
  contentType     String    @map("content_type") // tweet, caption, thread, story, reel_script, blog_post
  platform        String    // twitter, instagram, tiktok, youtube, linkedin
  status          String    @default("draft") // draft, scheduled, pending_approval, approved, published, rejected
  scheduledFor    DateTime? @map("scheduled_for")
  publishedAt     DateTime? @map("published_at")
  approvedAt      DateTime? @map("approved_at")
  approvedBy      String?   @map("approved_by")
  metadata        Json      @default("{}") // engagement metrics, generation params, etc.
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([characterId])
  @@index([status])
  @@index([scheduledFor])
  @@map("orbit_posts")
}
